SPRING_PROFILES_ACTIVE=local
BACKEND_PORT=8081

# Preferred: use API key directly.
GMS_API_KEY=replace-with-your-gms-api-key
# Or use the same name as CI/CD.
# GMS_KEY=replace-with-your-gms-api-key

# Optional: only needed if you want backend to fetch the GMS key dynamically.
GMS_ACCESS_TOKEN=

# Optional local basic-auth override for swagger/local testing.
SPRING_SECURITY_USER_NAME=jeolgamai_local
SPRING_SECURITY_USER_PASSWORD=jeolgamai-local-dev-only

# Optional: disable LLM enrichment if you want deterministic-only analysis.
OPTIMIZATION_AI_LLM_ENABLED=true
